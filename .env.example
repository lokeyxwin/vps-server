# 复制为 .env 后填入真实值

# 加密密钥（运行一次生成自己的）
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# 数据库类型：sqlite 或 mysql
DB_TYPE=sqlite

# MySQL（仅生产需要）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=vps_server

# ipinfo.io API token（rgIP 业务查询 IP 归属地用）
# 不填也能跑（匿名模式额度极小），注册 https://ipinfo.io/signup 拿免费 50k/月
IPINFO_TOKEN=

# 复制为 .env 后填入真实值。.env 不进 git。

# 密码加密密钥（首次本地跑一次生成，丢失=旧 DB 加密数据无法解开）
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# MySQL 密码（仅 config.py 切到 DB_TYPE="mysql" 时需要）
MYSQL_PASSWORD=

# ipinfo.io API token（rgIP 业务查询 IP 归属地用）
# 不填也能跑（匿名模式额度极小），注册 https://ipinfo.io/signup 拿免费 50k/月
IPINFO_TOKEN=
